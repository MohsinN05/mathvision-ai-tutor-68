PORT=4000
NODE_ENV=development

# Wolfram Alpha (https://developer.wolframalpha.com/)
WOLFRAM_APP_ID=

# Optional Python SymPy microservice
PYTHON_SOLVER_URL=http://localhost:5000

# Database (choose one)
MONGO_URI=mongodb://localhost:27017/mathvision
DATABASE_URL=postgres://user:pass@localhost:5432/mathvision

# CORS — comma separated origins for web/mobile clients
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,capacitor://localhost,http://localhost
