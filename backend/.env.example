# MongoDB connection string for auth and persistence
MONGO_URI=mongodb://localhost:27017/mathvision

# JWT secret used to sign login tokens
JWT_SECRET=replace_with_a_strong_secret

# Email verification settings
BASE_URL=http://localhost:4000
APP_BASE_URL=http://localhost:8081
EMAIL_FROM="MathVision <no-reply@mathvision.ai>"
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
SMTP_SECURE=false
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://localhost:8081,capacitor://localhost,http://localhost
